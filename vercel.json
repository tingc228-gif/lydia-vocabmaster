{
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "vite --port $PORT --host 0.0.0.0",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
